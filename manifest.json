{
  "manifest_version": 3,
  "name": "Lite Noodle",
  "version": "1.1",
  "description": "Automatically unloads inactive tabs to save memory.",
  "permissions": ["tabs", "storage", "alarms"],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Lite Noodle",
    "default_icon": "icon-light.svg",
    "theme_icons": [
      {
        "light": "icon-dark.svg",
        "dark": "icon-light.svg",
        "size": 32
      },
      {
        "light": "icon-dark.svg",
        "dark": "icon-light.svg",
        "size": 128
      }
    ]
  },
  "icons": {
    "128": "icon-light.svg"
  }
}
